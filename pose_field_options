<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Field Options · Pure Passion Yoga Admin</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
  :root {
    --rose: #C8A0A6;
    --sage: #a8ad91;
    --aubergine: #A87C83;
    --page-bg: #FBF8F6;
    --surface: #FFFFFF;
    --text: #3A3236;
    --muted: #8A7E82;
    --hairline: #ECE3E4;
    --rose-tint: #F6ECEE;
    --sage-tint: #EEF0E8;
    --danger: #B5544E;
    --ok: #6E8B5B;
    --radius: 12px;
    --shadow: 0 1px 2px rgba(58,50,54,.04), 0 6px 24px rgba(58,50,54,.06);
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body {
    font-family: 'Poppins', system-ui, sans-serif;
    background: var(--page-bg);
    color: var(--text);
    font-weight: 300;
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
  }
  h1, h2, h3 { font-family: 'Playfair Display', Georgia, serif; font-weight: 600; margin: 0; }
  button { font-family: inherit; cursor: pointer; }
  input, select { font-family: inherit; }
  @media (prefers-reduced-motion: reduce) { * { transition: none !important; animation: none !important; } }

  /* ---------- top bar ---------- */
  .topbar {
    display: flex; align-items: center; gap: 16px;
    padding: 18px 28px;
    background: var(--surface);
    border-bottom: 1px solid var(--hairline);
    position: sticky; top: 0; z-index: 20;
  }
  .brand { display: flex; flex-direction: column; line-height: 1.15; }
  .brand .eyebrow { font-size: 11px; letter-spacing: .18em; text-transform: uppercase; color: var(--rose); font-weight: 500; }
  .brand h1 { font-size: 22px; color: var(--text); }
  .topbar .spacer { flex: 1; }
  .who { font-size: 13px; color: var(--muted); text-align: right; }
  .who strong { color: var(--text); font-weight: 500; }
  .btn {
    border: 1px solid var(--hairline); background: var(--surface); color: var(--text);
    padding: 9px 16px; border-radius: 999px; font-size: 13px; font-weight: 500;
    transition: background .15s, border-color .15s, color .15s;
  }
  .btn:hover { border-color: var(--rose); color: var(--aubergine); }
  .btn.primary { background: var(--aubergine); border-color: var(--aubergine); color: #fff; }
  .btn.primary:hover { background: #93656d; border-color: #93656d; color: #fff; }
  .btn:disabled { opacity: .5; cursor: not-allowed; }
  .btn.icon { padding: 6px 10px; line-height: 1; font-size: 14px; }

  /* ---------- layout ---------- */
  .shell { display: grid; grid-template-columns: 264px 1fr; min-height: calc(100vh - 61px); }
  .sidebar { border-right: 1px solid var(--hairline); background: var(--surface); padding: 18px 12px; }
  .sidebar .lede { padding: 4px 12px 14px; font-size: 12.5px; color: var(--muted); }
  .grouplist { display: flex; flex-direction: column; gap: 2px; }
  .groupbtn {
    display: flex; align-items: center; gap: 10px; width: 100%;
    border: none; background: transparent; color: var(--text);
    padding: 10px 12px; border-radius: 10px; text-align: left; font-size: 14px; font-weight: 400;
    transition: background .12s;
  }
  .groupbtn:hover { background: var(--rose-tint); }
  .groupbtn.active { background: var(--rose-tint); color: var(--aubergine); font-weight: 500; }
  .groupbtn .count {
    margin-left: auto; font-size: 11px; color: var(--muted);
    background: var(--page-bg); border: 1px solid var(--hairline); border-radius: 999px; padding: 1px 9px;
  }
  .groupbtn.active .count { color: var(--aubergine); border-color: #e3cdd1; background: #fff; }

  .main { padding: 28px 32px 80px; max-width: 920px; }
  .main-head { margin-bottom: 6px; display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap; }
  .main-head h2 { font-size: 27px; }
  .main-head .col { font-size: 12px; color: var(--muted); font-family: 'Poppins'; }
  .hint {
    background: var(--sage-tint); border: 1px solid #dfe3d3; color: #5d6747;
    border-radius: 10px; padding: 10px 14px; font-size: 12.5px; margin: 16px 0 22px;
  }
  .hint code { background: #fff; border: 1px solid #dfe3d3; border-radius: 5px; padding: 1px 6px; font-size: 12px; }

  /* ---------- add row ---------- */
  .addrow {
    display: flex; gap: 10px; align-items: center; margin-bottom: 18px; flex-wrap: wrap;
    background: var(--surface); border: 1px solid var(--hairline); border-radius: var(--radius);
    padding: 14px 16px; box-shadow: var(--shadow);
  }
  .addrow input {
    border: 1px solid var(--hairline); border-radius: 9px; padding: 9px 12px; font-size: 14px; color: var(--text);
    background: var(--page-bg); transition: border-color .15s, background .15s;
  }
  .addrow input:focus { outline: none; border-color: var(--rose); background: #fff; }
  .addrow .val-in { flex: 1 1 220px; }
  .addrow .label-in { flex: 1 1 180px; }

  /* ---------- options table ---------- */
  .opts { display: flex; flex-direction: column; gap: 8px; }
  .opt {
    display: flex; align-items: center; gap: 14px; flex-wrap: wrap;
    background: var(--surface); border: 1px solid var(--hairline); border-radius: var(--radius);
    padding: 10px 14px; box-shadow: var(--shadow);
  }
  .opt .maincol { flex: 1 1 220px; min-width: 0; display: flex; flex-direction: column; gap: 1px; }
  .opt.inactive { opacity: .55; }
  .reorder { display: flex; flex-direction: column; gap: 2px; }
  .reorder button {
    border: none; background: transparent; color: var(--muted); padding: 0; font-size: 11px; line-height: 1;
  }
  .reorder button:hover { color: var(--aubergine); }
  .reorder button:disabled { opacity: .3; cursor: default; }
  .opt .value { font-size: 14.5px; font-weight: 400; color: var(--text); display: flex; align-items: center; gap: 8px; }
  .opt .value .lock { font-size: 11px; color: var(--muted); }
  .opt .label-edit {
    border: 1px solid transparent; background: transparent; border-radius: 7px; padding: 4px 8px;
    font-size: 12.5px; color: var(--muted); width: 100%; max-width: 340px; transition: border-color .15s, background .15s, color .15s;
  }
  .opt .label-edit:hover { border-color: var(--hairline); }
  .opt .label-edit:focus { outline: none; border-color: var(--rose); background: var(--page-bg); color: var(--text); }
  .usage { font-size: 12px; color: var(--muted); white-space: nowrap; margin-left: auto; }
  .usage b { color: var(--text); font-weight: 500; }
  .usage.zero { color: #b9adb1; }
  .opt .actions { display: flex; align-items: center; gap: 6px; justify-self: end; }
  .toggle {
    border: 1px solid var(--hairline); background: var(--page-bg); border-radius: 999px;
    font-size: 11px; padding: 4px 11px; color: var(--muted); font-weight: 500;
  }
  .toggle.on { background: var(--sage-tint); border-color: #cdd4ba; color: var(--ok); }
  .del { border: none; background: transparent; color: #c9a9ac; padding: 6px; font-size: 14px; border-radius: 7px; }
  .del:hover { background: #f7ecec; color: var(--danger); }

  .empty { color: var(--muted); font-size: 14px; padding: 30px 4px; }

  /* ---------- auth gate ---------- */
  .gate { min-height: 100vh; display: grid; place-items: center; padding: 24px; }
  .card {
    width: 100%; max-width: 380px; background: var(--surface); border: 1px solid var(--hairline);
    border-radius: 18px; padding: 34px 30px; box-shadow: var(--shadow);
  }
  .card .eyebrow { font-size: 11px; letter-spacing: .18em; text-transform: uppercase; color: var(--rose); font-weight: 500; }
  .card h1 { font-size: 25px; margin: 6px 0 4px; }
  .card p { font-size: 13px; color: var(--muted); margin: 0 0 22px; }
  .field { margin-bottom: 14px; }
  .field label { display: block; font-size: 12px; color: var(--muted); margin-bottom: 6px; font-weight: 500; }
  .field input {
    width: 100%; border: 1px solid var(--hairline); border-radius: 10px; padding: 11px 13px; font-size: 14px;
    background: var(--page-bg); color: var(--text);
  }
  .field input:focus { outline: none; border-color: var(--rose); background: #fff; }
  .card .btn.primary { width: 100%; padding: 12px; margin-top: 6px; }

  .msg { font-size: 13px; padding: 10px 14px; border-radius: 10px; margin-bottom: 16px; display: none; }
  .msg.show { display: block; }
  .msg.err { background: #f9ecec; border: 1px solid #eccfcf; color: var(--danger); }
  .msg.ok  { background: var(--sage-tint); border: 1px solid #cdd4ba; color: var(--ok); }

  .toast {
    position: fixed; bottom: 22px; left: 50%; transform: translateX(-50%) translateY(20px);
    background: var(--text); color: #fff; padding: 11px 20px; border-radius: 999px; font-size: 13px;
    opacity: 0; pointer-events: none; transition: opacity .2s, transform .2s; z-index: 50;
  }
  .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

  @media (max-width: 760px) {
    .shell { grid-template-columns: 1fr; }
    .sidebar { border-right: none; border-bottom: 1px solid var(--hairline); }
    .grouplist { flex-direction: row; flex-wrap: wrap; }
    .groupbtn { width: auto; }
    .opt .label-edit { max-width: none; }
    .usage { margin-left: 0; }
    .main { padding: 22px 18px 70px; }
  }
</style>
</head>
<body>

<!-- ======== AUTH GATE ======== -->
<div id="gate" class="gate">
  <div class="card">
    <div class="eyebrow">Pure Passion Yoga</div>
    <h1>Field Options</h1>
    <p>Sign in with your admin account to manage the pose selection lists.</p>
    <div id="authMsg" class="msg err"></div>
    <div class="field">
      <label for="email">Email</label>
      <input id="email" type="email" autocomplete="username" placeholder="you@purepassionyoga.com" />
    </div>
    <div class="field">
      <label for="password">Password</label>
      <input id="password" type="password" autocomplete="current-password" placeholder="••••••••" />
    </div>
    <button id="signInBtn" class="btn primary">Sign in</button>
  </div>
</div>

<!-- ======== APP ======== -->
<div id="app" style="display:none;">
  <div class="topbar">
    <div class="brand">
      <span class="eyebrow">Pure Passion Yoga · Admin</span>
      <h1>Field Options</h1>
    </div>
    <div class="spacer"></div>
    <div class="who" id="who"></div>
    <button id="signOutBtn" class="btn">Sign out</button>
  </div>

  <div class="shell">
    <aside class="sidebar">
      <div class="lede">Lists that fill the dropdowns in the pose editor. Add, rename, reorder, or retire values.</div>
      <nav class="grouplist" id="grouplist"></nav>
    </aside>

    <main class="main">
      <div class="main-head">
        <h2 id="groupTitle">Categories</h2>
        <span class="col" id="groupCount"></span>
      </div>
      <div class="hint" id="groupHint"></div>

      <div class="addrow">
        <input class="val-in" id="newValue" placeholder="New value (stored on the pose)" />
        <input class="label-in" id="newLabel" placeholder="Display label (optional)" />
        <button class="btn primary" id="addBtn">Add option</button>
      </div>

      <div class="opts" id="opts"></div>
    </main>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
/* =========================================================================
   CONFIG  —  paste your Supabase anon (public) key below.
   The URL is already set for the Pure Passion Yoga project.
   The anon key is safe to ship in client code; row-level security
   restricts writes to admin accounts (profiles.is_admin = true).
   ========================================================================= */
const SUPABASE_URL = "https://nxjbpgnpblqepathojzr.supabase.co";
const SUPABASE_ANON_KEY = "YOUR_SUPABASE_ANON_KEY";

/* Field groups — fixed to the columns that exist on the poses table.
   value-format hints prevent malformed entries (suffix conventions matter). */
const GROUPS = [
  { key: "category",              title: "Categories",           hint: "One per pose. A new category becomes its own filter bucket. Examples: <code>Standing</code>, <code>Inversion</code>." },
  { key: "level",                 title: "Levels",               hint: "Difficulty tiers. Editing these is rare — the app expects <code>Beginner</code>, <code>Intermediate</code>, <code>Advanced</code>." },
  { key: "chakras",               title: "Chakras",              hint: "Use the <code>… Chakra</code> suffix, e.g. <code>Throat Chakra</code>." },
  { key: "body_focus",            title: "Body Focus",           hint: "Areas of the body a pose targets, e.g. <code>Hips</code>, <code>Spine</code>." },
  { key: "muscle_groups",         title: "Muscle Groups",        hint: "Specific muscles worked, e.g. <code>Hamstrings</code>, <code>Glutes</code>." },
  { key: "required_props",        title: "Props",                hint: "Equipment a pose may use, e.g. <code>Block</code>, <code>Bolster</code>, <code>Strap</code>." },
  { key: "yoga_styles",           title: "Yoga Styles",          hint: "Use the <code>… Yoga</code> suffix (except <code>Meditation</code>), e.g. <code>Aerial Yoga</code>." },
  { key: "pose_phases",           title: "Pose Phases",          hint: "Where a pose fits in a sequence, e.g. <code>Warm Up</code>, <code>Peak Pose</code>, <code>Cool Down</code>." },
  { key: "movement_actions",      title: "Movement Actions",     hint: "Joint actions, e.g. <code>Hip Flexion</code>, <code>Spinal Rotation</code>." },
  { key: "benefit_tags",          title: "Benefit Tags",         hint: "Short benefit keywords, e.g. <code>Flexibility</code>, <code>Calming</code>." },
  { key: "contraindication_tags", title: "Contraindication Tags",hint: "Caution keywords, e.g. <code>Knee Injury</code>, <code>Pregnancy</code>." },
];

const sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

let STATE = { options: [], usage: {}, current: "category" };

/* ---------- helpers ---------- */
const $ = (id) => document.getElementById(id);
function toast(text) {
  const t = $("toast"); t.textContent = text; t.classList.add("show");
  clearTimeout(t._t); t._t = setTimeout(() => t.classList.remove("show"), 2200);
}
function authMsg(text, kind) {
  const m = $("authMsg"); m.textContent = text;
  m.className = "msg " + (kind || "err") + (text ? " show" : "");
}
function groupOf(key) { return GROUPS.find(g => g.key === key); }

/* ---------- auth ---------- */
async function refreshSession() {
  const { data } = await sb.auth.getSession();
  if (data.session) { await enterApp(data.session); }
  else { $("gate").style.display = "grid"; $("app").style.display = "none"; }
}
async function enterApp(session) {
  $("gate").style.display = "none";
  $("app").style.display = "block";
  $("who").innerHTML = "Signed in as <strong>" + (session.user.email || "admin") + "</strong>";
  await loadAll();
  renderGroups();
  selectGroup(STATE.current);
}
$("signInBtn").onclick = async () => {
  authMsg("");
  const email = $("email").value.trim(), password = $("password").value;
  if (!email || !password) { authMsg("Enter your email and password."); return; }
  $("signInBtn").disabled = true; $("signInBtn").textContent = "Signing in…";
  const { data, error } = await sb.auth.signInWithPassword({ email, password });
  $("signInBtn").disabled = false; $("signInBtn").textContent = "Sign in";
  if (error) { authMsg(error.message); return; }
  await enterApp(data.session);
};
$("password").addEventListener("keydown", (e) => { if (e.key === "Enter") $("signInBtn").click(); });
$("signOutBtn").onclick = async () => { await sb.auth.signOut(); location.reload(); };

/* ---------- data ---------- */
async function loadAll() {
  const [{ data: opts, error: e1 }, { data: use, error: e2 }] = await Promise.all([
    sb.from("pose_field_options").select("*").order("field_key").order("sort_order"),
    sb.rpc("get_field_option_usage"),
  ]);
  if (e1) { toast("Could not load options"); console.error(e1); }
  STATE.options = opts || [];
  STATE.usage = {};
  (use || []).forEach(r => { STATE.usage[r.field_key + "|" + r.value] = Number(r.n); });
}
function optionsFor(key) {
  return STATE.options.filter(o => o.field_key === key)
    .sort((a, b) => a.sort_order - b.sort_order || a.value.localeCompare(b.value));
}
function usageFor(key, value) { return STATE.usage[key + "|" + value] || 0; }

/* ---------- render: sidebar ---------- */
function renderGroups() {
  const wrap = $("grouplist"); wrap.innerHTML = "";
  GROUPS.forEach(g => {
    const n = optionsFor(g.key).length;
    const b = document.createElement("button");
    b.className = "groupbtn" + (g.key === STATE.current ? " active" : "");
    b.innerHTML = "<span>" + g.title + "</span><span class='count'>" + n + "</span>";
    b.onclick = () => selectGroup(g.key);
    wrap.appendChild(b);
  });
}

/* ---------- render: main ---------- */
function selectGroup(key) {
  STATE.current = key;
  const g = groupOf(key);
  $("groupTitle").textContent = g.title;
  $("groupHint").innerHTML = g.hint;
  $("newValue").value = ""; $("newLabel").value = "";
  renderGroups();
  renderOptions();
}
function renderOptions() {
  const key = STATE.current;
  const list = optionsFor(key);
  const total = list.reduce((s, o) => s + usageFor(key, o.value), 0);
  $("groupCount").textContent = list.length + " option" + (list.length === 1 ? "" : "s") + " · " + total + " uses across the catalog";
  const wrap = $("opts"); wrap.innerHTML = "";
  if (!list.length) { wrap.innerHTML = "<div class='empty'>No options yet. Add the first one above.</div>"; return; }

  list.forEach((o, i) => {
    const uses = usageFor(key, o.value);
    const row = document.createElement("div");
    row.className = "opt" + (o.is_active ? "" : " inactive");

    // reorder
    const re = document.createElement("div");
    re.className = "reorder";
    const up = document.createElement("button"); up.innerHTML = "▲"; up.title = "Move up";
    up.disabled = i === 0; up.onclick = () => move(o, -1);
    const dn = document.createElement("button"); dn.innerHTML = "▼"; dn.title = "Move down";
    dn.disabled = i === list.length - 1; dn.onclick = () => move(o, 1);
    re.append(up, dn);

    // value (locked) + editable label, stacked in a main column
    const main = document.createElement("div");
    main.className = "maincol";
    const val = document.createElement("div");
    val.className = "value";
    val.innerHTML = "<span>" + escapeHtml(o.value) + "</span><span class='lock' title='The stored value is locked to protect existing poses'>🔒</span>";
    const lab = document.createElement("input");
    lab.className = "label-edit"; lab.value = o.label || "";
    lab.placeholder = "Display label · defaults to “" + o.value + "”"; lab.title = "Display label";
    lab.onchange = () => updateLabel(o, lab.value.trim());
    main.append(val, lab);

    // usage
    const us = document.createElement("div");
    us.className = "usage" + (uses === 0 ? " zero" : "");
    us.innerHTML = uses === 0 ? "unused" : "<b>" + uses + "</b> pose" + (uses === 1 ? "" : "s");

    // actions
    const act = document.createElement("div");
    act.className = "actions";
    const tg = document.createElement("button");
    tg.className = "toggle" + (o.is_active ? " on" : "");
    tg.textContent = o.is_active ? "Active" : "Hidden";
    tg.title = o.is_active ? "Showing in dropdowns — click to hide" : "Hidden from dropdowns — click to show";
    tg.onclick = () => toggleActive(o);
    const del = document.createElement("button");
    del.className = "del"; del.innerHTML = "✕"; del.title = "Delete option";
    del.onclick = () => removeOption(o, uses);
    act.append(tg, del);

    row.append(re, main, us, act);
    wrap.appendChild(row);
  });
}
function escapeHtml(s){ return s.replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }

/* ---------- mutations ---------- */
$("addBtn").onclick = async () => {
  const key = STATE.current;
  const value = $("newValue").value.trim();
  const label = $("newLabel").value.trim();
  if (!value) { toast("Enter a value first"); $("newValue").focus(); return; }
  const exists = optionsFor(key).some(o => o.value.toLowerCase() === value.toLowerCase());
  if (exists) { toast("That value already exists"); return; }
  const nextSort = Math.max(0, ...optionsFor(key).map(o => o.sort_order)) + 1;
  const { error } = await sb.from("pose_field_options")
    .insert({ field_key: key, value, label: label || null, sort_order: nextSort, is_active: true });
  if (error) { toast(error.message.includes("row-level") ? "Admin access required" : "Could not add"); console.error(error); return; }
  $("newValue").value = ""; $("newLabel").value = "";
  await loadAll(); renderGroups(); renderOptions();
  toast("Added “" + value + "”");
};
async function updateLabel(o, label) {
  if ((o.label || "") === label) return;
  const { error } = await sb.from("pose_field_options").update({ label: label || null }).eq("id", o.id);
  if (error) { toast("Could not save label"); return; }
  o.label = label || null; toast("Label saved");
}
async function toggleActive(o) {
  const next = !o.is_active;
  const { error } = await sb.from("pose_field_options").update({ is_active: next }).eq("id", o.id);
  if (error) { toast("Could not update"); return; }
  o.is_active = next; renderOptions();
  toast(next ? "Showing in dropdowns" : "Hidden from dropdowns");
}
async function move(o, dir) {
  const list = optionsFor(STATE.current);
  const i = list.findIndex(x => x.id === o.id);
  const j = i + dir;
  if (j < 0 || j >= list.length) return;
  const a = list[i], b = list[j];
  const [sa, sb_] = [a.sort_order, b.sort_order];
  await Promise.all([
    sb.from("pose_field_options").update({ sort_order: sb_ }).eq("id", a.id),
    sb.from("pose_field_options").update({ sort_order: sa }).eq("id", b.id),
  ]);
  a.sort_order = sb_; b.sort_order = sa;
  renderOptions();
}
async function removeOption(o, uses) {
  let warn = "Delete “" + o.value + "”?";
  if (uses > 0) warn += "\n\n" + uses + " pose" + (uses === 1 ? "" : "s") + " still use this value. Deleting it removes the dropdown option, but those poses keep the value until you re-tag them. Consider hiding it instead.";
  if (!confirm(warn)) return;
  const { error } = await sb.from("pose_field_options").delete().eq("id", o.id);
  if (error) { toast("Could not delete"); return; }
  await loadAll(); renderGroups(); renderOptions();
  toast("Deleted “" + o.value + "”");
}
$("newValue").addEventListener("keydown", (e) => { if (e.key === "Enter") $("addBtn").click(); });
$("newLabel").addEventListener("keydown", (e) => { if (e.key === "Enter") $("addBtn").click(); });

/* ---------- boot ---------- */
if (SUPABASE_ANON_KEY === "YOUR_SUPABASE_ANON_KEY") {
  authMsg("Add your Supabase anon key in the CONFIG block at the top of this file to enable sign-in.");
}
refreshSession();
sb.auth.onAuthStateChange((_e, session) => { if (!session) { $("gate").style.display = "grid"; $("app").style.display = "none"; } });
</script>
</body>
